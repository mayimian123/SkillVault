# Sepolia RPC endpoint — get from Alchemy (https://alchemy.com) or Infura (free tier)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Oracle wallet private key — this wallet must be set as `oracle` in the deployed contract
# Must have Sepolia ETH to pay gas (get from https://sepoliafaucet.com)
ORACLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Deployed SkillVault proxy contract address on Sepolia
SKILL_VAULT_ADDRESS=0xYOUR_CONTRACT_ADDRESS

# DeepSeek API key — get from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY
