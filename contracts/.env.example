# Sepolia RPC - get a free key from https://alchemy.com
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the wallet you're deploying from (must have Sepolia ETH)
# This wallet will also become the fee recipient by default
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Oracle wallet address - the wallet that runs oracle/index.js
ORACLE_ADDRESS=0x0444133DF40f07eE1D051A247Aaf7fCe643D171c

# Optional: override fee recipient (defaults to deployer)
FEE_RECIPIENT_ADDRESS=0xYOUR_FEE_RECIPIENT_ADDRESS

# Optional: reuse an already deployed VaultToken instead of deploying a new one
EXISTING_VAULT_TOKEN_ADDRESS=0xYOUR_EXISTING_VAULT_TOKEN_ADDRESS
